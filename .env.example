# Copy this file to `.env.local` (gitignored) and fill in real values.
# All variables MUST be prefixed VITE_ to be exposed to the browser.

# Global student id used by all adapters unless overridden.
VITE_STUDENT_ID=samuel

# ---------- Math Academy (via official Beta 5 partner API proxy) ----------
# The adapter calls our serverless proxy, not mathacademy.com directly.
# The proxy holds the Public-API-Key server-side; the browser never sees it.
# Defaults below are correct for production — you only need to override
# them in local dev if you're hitting a different proxy deployment.
VITE_MA_API_BASE_URL=https://math-facts-trainer.vercel.app
VITE_MA_SNAPSHOT_PATH=/api/math-academy/snapshot
VITE_MA_DEEP_LINK=https://www.mathacademy.com
VITE_MA_STUDENT_ID=

# ---------- Math Facts (in-house) ----------
VITE_MF_BASE_URL=https://math-facts-trainer.vercel.app
VITE_MF_SNAPSHOT_PATH=/api/snapshot
VITE_MF_STUDENT_ID=

# ---------- Reading Facts (in-house) ----------
VITE_RF_BASE_URL=https://reading-facts-app.vercel.app
VITE_RF_SNAPSHOT_PATH=/api/snapshot
VITE_RF_STUDENT_ID=

# ---------- Polling ----------
# How often the dashboard re-fetches every adapter, in milliseconds.
VITE_POLL_INTERVAL_MS=60000
